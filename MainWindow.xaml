<Window x:Class="AppuntiPerInformatici_Dadci_Yasser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dev-Stack Manager" Height="650" Width="950" 
        Background="#121212" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="0,15,15,0">
            <StackPanel Margin="10">
                <TextBlock Text="INFO NOTES" Foreground="#00ADB5" FontSize="22" FontWeight="Bold" Margin="0,15,0,25" HorizontalAlignment="Center"/>

                <Button x:Name="btnGestioneFile" Content="GestioneFile" Height="35" Margin="0,2" Foreground="White" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="10,0"/>
                <Button x:Name="btnWPF" Content="WPF" Height="35" Margin="0,2" Foreground="White" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="10,0"/>
                <Button x:Name="btnDelegate" Content="Delegate" Height="35" Margin="0,2" Foreground="White" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="10,0"/>
                <Button x:Name="btnDizionari" Content="Dizionari" Height="35" Margin="0,2" Foreground="White" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="10,0"/>
                <Button x:Name="btnCode" Content="Code" Height="35" Margin="0,2" Foreground="White" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="10,0"/>
                <Button x:Name="btnPile" Content="Pile" Height="35" Margin="0,2" Foreground="White" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="10,0"/>

                <Separator Margin="0,20" Background="#333333"/>
                <Button x:Name="btnRecupera" Content="🔎 RECUPERA" Height="45" Background="#00ADB5" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">

            <StackPanel x:Name="pnlScrittura" Visibility="Visible">
                <TextBlock Text="TITOLO APPUNTO" Foreground="#888888" FontSize="10" Margin="0,0,0,5"/>
                <TextBox x:Name="txtTitolo" Height="35" Background="#2D2D2D" Foreground="White" BorderThickness="0" Padding="10,5" VerticalContentAlignment="Center"/>

                <TextBlock Text="CONTENUTO / CODICE" Foreground="#888888" FontSize="10" Margin="0,20,0,5"/>
                <TextBox x:Name="txtContenuto" Height="250" Background="#2D2D2D" Foreground="#A9E190" BorderThickness="0" AcceptsReturn="True" Padding="10" FontFamily="Consolas" VerticalScrollBarVisibility="Auto"/>

                <Button x:Name="btnSalva" Content="SALVA NEL FILE" Height="40" Margin="0,10,0,0" Background="#00ADB5" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                <TextBlock x:Name="lblStato" Text="Seleziona una categoria" Foreground="#555555" Margin="0,15,0,5"/>
            </StackPanel>

            <StackPanel x:Name="pnlLettura" Visibility="Collapsed">
                <Button x:Name="btnIndietro" Content="← TORNA A SCRIVERE" HorizontalAlignment="Left" Background="Transparent" Foreground="#00ADB5" BorderThickness="0" FontWeight="Bold" Margin="0,0,0,10"/>

                <ListBox x:Name="lstArchivio" Height="400" Background="#1E1E1E" BorderThickness="0" SelectionChanged="lstArchivio_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5,10">
                                <TextBlock Text="{Binding Titolo}" Foreground="Red" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding Contenuto}" Foreground="White" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" MaxHeight="20"/>
                                <Separator Background="#333333" Margin="0,10,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Grid>
        <Button Content="❌ ELIMINA" HorizontalAlignment="Center" Margin="0,404,0,0" VerticalAlignment="Top" Width="200" Height="45" IsCancel="True" Background="#FFFB0505" Foreground="White" FontWeight="Bold" Click="Button_Click"/>
    </Grid>
</Window>